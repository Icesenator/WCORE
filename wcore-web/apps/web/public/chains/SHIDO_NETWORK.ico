    <script>
        // Mock React Refresh runtime to prevent errors in environments that serve dev builds without HMR
        window.$RefreshReg$ = () => {};
        window.$RefreshSig$ = () => () => {};
    </script>
    <script>
        tailwind.config = {
            darkMode: 'class', // Enable class-based dark mode
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Chakra Petch', 'sans-serif'],
                        display: ['Rajdhani', 'sans-serif'],
                        mono: ['ui-monospace', 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', "Liberation Mono", "Courier New", 'monospace'],
                    },
                    colors: {
                        shido: {
                            bg: 'rgb(var(--shido-bg))',
                            card: 'rgb(var(--shido-card))',
                            cyan: 'rgb(var(--shido-cyan))',
                            purple: 'rgb(var(--shido-purple))',
                            border: 'rgb(var(--shido-border))',
                            dark: 'rgb(var(--shido-dark))',
                            success: 'rgb(var(--shido-success))',
                            warning: 'rgb(var(--shido-warning))',
                            danger: 'rgb(var(--shido-danger))',
                        },
                        // Redefine base colors to use CSS variables for theming
                        'text-primary': 'rgb(var(--text-primary))',
                        'text-secondary': 'rgb(var(--text-secondary))',
                        'text-tertiary': 'rgb(var(--text-tertiary))',
                        'text-accent': 'rgb(var(--text-accent))',
                        'text-inverted': 'rgb(var(--text-inverted))',
                        'transparent': 'transparent',
                    },
                    textColor: {
                        // Ensure text color utilities also use variables
                        primary: 'rgb(var(--text-primary))',
                        secondary: 'rgb(var(--text-secondary))',
tertiary: 'rgb(var(--text-tertiary))',
                        accent: 'rgb(var(--text-accent))',
                        inverted: 'rgb(var(--text-inverted))',
                    },
                    backgroundColor: {
                        // Ensure background color utilities also use variables
                        bg: 'rgb(var(--shido-bg))',
                        card: 'rgb(var(--shido-card))',
                        dark: 'rgb(var(--shido-dark))',
                    },
                    borderColor: {
                        // Ensure border color utilities also use variables
                        DEFAULT: 'rgb(var(--shido-border))',
                        cyan: 'rgb(var(--shido-cyan))',
                        purple: 'rgb(var(--shido-purple))',
                    },
                    backgroundImage: {
                        'gradient-radial': 'radial-gradient(var(--tw-gradient-stops))',
                        'cyber-grid': 'linear-gradient(rgba(var(--shido-cyan), 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(var(--shido-cyan), 0.03) 1px, transparent 1px)',
                        'hex-pattern': `url("data:image/svg+xml,%3Csvg width='24' height='40' viewBox='0 0 24 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 40c5.523 0 10-4.477 10-10V10c0-5.523 4.477-10 10-10H0v40z' fill='rgb(var(--shido-cyan))' fill-opacity='0.03' fill-rule='evenodd'/%3E%3C/svg%3E")`,
                    },
                    animation: {
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'float': 'float 6s ease-in-out infinite',
                        'spin-slow': 'spin 15s linear infinite',
                        'shimmer': 'shimmer 2s infinite',
                        'scan': 'scan 4s linear infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-20px)' },
                        },
                        shimmer: {
                            '0%': { transform: 'translateX(-100%)' },
                            '100%': { transform: 'translateX(100%)' }
                        },
                        scan: {
                            '0%': { transform: 'translateY(-100%)' },
                            '100%': { transform: 'translateY(100%)' }
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .clip-slant-right {
             clip-path: polygon(0 0, 100% 0, 90% 100%, 0% 100%);
        }
        .corner-brackets {
            position: relative;
        }
        .corner-brackets::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 10px;
            height: 10px;
            border-top: 2px solid rgba(var(--shido-cyan), 0.5);
            border-left: 2px solid rgba(var(--shido-cyan), 0.5);
        }
        .corner-brackets::after {
            content: '';
            position: absolute;
            bottom: 0;
            right: 0;
            width: 10px;
            height: 10px;
            border-bottom: 2px solid rgba(var(--shido-cyan), 0.5);
            border-right: 2px solid rgba(var(--shido-cyan), 0.5);
        }
    </style>

