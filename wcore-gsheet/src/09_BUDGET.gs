// ============================================================
// CHAIN EXEC STATS (light persistence in SheetCache)
// ============================================================

/**
 * Stores a small rolling history of execution times per CHAIN (not per wallet).
 * Key: config.KEYS.DYNAMIC_BUDGET_PREFIX + "CHAIN"
 * Stored in SheetCache (__CACHE__) to avoid ScriptProperties quota.
 *
 * Format JSON: { ts, arr:[..], ema, emaBal, emaPrice }
 */
var ChainExecStats = {
 _key: function(config) {
 try {
 var p = (config && config.KEYS && config.KEYS.DYNAMIC_BUDGET_PREFIX) ? String(config.KEYS.DYNAMIC_BUDGET_PREFIX) : null;
 if (!p) return null;
 return p + "CHAIN";
 } catch (e) { return null; }
 },

 load: function(config) {
 var key = this._key(config);
 if (!key) return null;
 try {
 var raw = (typeof SheetCache !== "undefined" && SheetCache && SheetCache.getRaw) ? SheetCache.getRaw(key) : null;
 if (!raw) return null;
 var obj = JSON.parse(String(raw));
 if (!obj || typeof obj !== "object") return null;
 if (!Array.isArray(obj.arr)) obj.arr = [];
 return obj;
 } catch (e) { return null; }
 },

 save: function(config, execMs, balMs, priceMs) {
 var key = this._key(config);
 if (!key) return;
 try {
 execMs = (execMs|0);
 balMs = (balMs|0);
 priceMs = (priceMs|0);
 var obj = this.load(config) || { ts: 0, arr: [], ema: 0, emaBal: 0, emaPrice: 0 };
 var arr = obj.arr || [];
 arr.push(execMs);
 while (arr.length > 8) arr.shift();
 obj.arr = arr;
 // EMA (0.35 new)
 var a = 0.35;
 obj.ema = obj.ema ? Math.round((1-a)*obj.ema + a*execMs) : execMs;
 if (balMs > 0) obj.emaBal = obj.emaBal ? Math.round((1-a)*obj.emaBal + a*balMs) : balMs;
 if (priceMs > 0) obj.emaPrice = obj.emaPrice ? Math.round((1-a)*obj.emaPrice + a*priceMs) : priceMs;
 obj.ts = Date.now();
 // TTL 30 days
 if (typeof SheetCache !== "undefined" && SheetCache && SheetCache.setRaw) {
 SheetCache.setRaw(key, JSON.stringify(obj), 30*24*3600);
 }
 } catch (e) {}
 },

 p90: function(obj) {
 try {
 var arr = (obj && obj.arr && obj.arr.length) ? obj.arr.slice() : [];
 if (!arr.length) return 0;
 arr.sort(function(a,b){return a-b;});
 var idx = Math.max(0, Math.min(arr.length-1, Math.floor(0.9*(arr.length-1))));
 return arr[idx] | 0;
 } catch (e) { return 0; }
 }
};

