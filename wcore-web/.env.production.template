# WCORE Production Environment Template
# Copy to .env.production.local and fill in real secrets
# Never commit .env.production.local

# --- Database ---
DB_USER=wcore
DB_PASSWORD=change-me-prod-64-chars
DB_NAME=wcore
DB_PORT=5432

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-prod

# --- API ---
API_PORT=4000
JWT_SECRET=change-me-prod-jwt-64-chars-minimum
CORS_ORIGIN=https://your-domain.com
RATE_LIMIT_SCAN=60
RATE_LIMIT_AUTH=30

# --- Web ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# --- WalletConnect ---
NEXT_PUBLIC_WC_PROJECT_ID=your-walletconnect-project-id

# --- Blockscout Pro API ---
# Used only for ERC-20 contract discovery hints, never for balances.
# Blockscout Pro docs use api.blockscout.com/v2/api with chain_id + apikey.
# Do not assume Pro quota applies to per-explorer /api/v2 routes without verification.
# If exhausted or unhealthy, scans fall back to RPC log discovery.
BLOCKSCOUT_API_KEY=
# BLOCKSCOUT_DISABLE=0
# BLOCKSCOUT_TIMEOUT_MS=2500
# BLOCKSCOUT_COOLDOWN_MS=600000

