# Copy to .env (kept out of git) and adjust as needed.

# --- API (apps/api) ---
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=https://wcore.xyz
# Required in production (apps/api throws on boot if missing/weak). 32+ char random.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
# Bearer header auth fallback (legacy/tooling). Deny-by-default in production:
# only `AUTH_ALLOW_BEARER=true` re-enables it. Outside production it stays on
# unless set to `false`. The web app uses httpOnly cookies exclusively.
AUTH_ALLOW_BEARER=

# --- Web (apps/web) ---
# Production value (Railway): https://api-production-b5bf.up.railway.app
# (api.wcore.xyz has no DNS record — do not use until created at the registrar)
NEXT_PUBLIC_API_URL=https://api-production-b5bf.up.railway.app

# --- WalletConnect (apps/web) ---
# Get a free Project ID at https://cloud.reown.com — enables WalletConnect + Coinbase Wallet
NEXT_PUBLIC_WC_PROJECT_ID=

# --- Postgres (docker-compose.dev.yml) ---
DATABASE_URL=postgresql://USER:PASSWORD@RAILWAY_HOST:RAILWAY_PORT/railway
# Optional for API tests. Use a Railway test/staging database, never production.
TEST_DATABASE_URL=postgresql://USER:PASSWORD@RAILWAY_TEST_HOST:RAILWAY_TEST_PORT/railway

# --- Redis (docker-compose.dev.yml) ---
REDIS_URL=redis://default:PASSWORD@RAILWAY_REDIS_HOST:RAILWAY_REDIS_PORT
# Optional for API tests. Use a Railway test/staging Redis, never production.
TEST_REDIS_URL=redis://default:PASSWORD@RAILWAY_TEST_REDIS_HOST:RAILWAY_TEST_REDIS_PORT

# --- Admin / ops (apps/api) ---
# Required to access admin/ops endpoints (metrics detail, scam-overrides, gm/backfill).
# Sent as `Authorization: Bearer <token>` or `x-admin-token` header. Compared with
# timingSafeEqual. Leave unset to disable all admin endpoints (they return 401).
ADMIN_TOKEN=

# --- Rate limiting (apps/api) ---
RATE_LIMIT_SCAN=2000
RATE_LIMIT_SCAN_ANON=100
RATE_LIMIT_AUTH=30
# GM read endpoints (/api/gm/status, /api/gm/random, /api/gm/has-deployed). The
# /gm page renders ~30 cards; keep generous so a page load never 429s the header GM.
RATE_LIMIT_GM_READ=300
RATE_LIMIT_GM_READ_ANON=60
MAX_CHAINS_PER_SCAN=120
ANONYMOUS_MAX_CHAINS_PER_SCAN=20
# SCAN_CONCURRENCY: unset = 50 (default since 2026-05-27 with pre-warm pricing optimization;
# 62/180 chains have a single RPC endpoint). >50 saturates public RPCs.
# Set higher for raw speed at the cost of more DEGRADED results.
# SCAN_CONCURRENCY=
# Frontend must match backend concurrency to avoid bottleneck.
# NEXT_PUBLIC_SCAN_CONCURRENCY=50
# PERF-8: chains batched per /api/scan/batch request (default 5). Larger = fewer
# HTTP requests but coarser progressive UI updates. Job concurrency is divided by
# this so chains-in-flight stays ≈ NEXT_PUBLIC_SCAN_CONCURRENCY.
# NEXT_PUBLIC_CHAIN_BATCH_SIZE=5
# Note: DEPLOY.md may have stale values — this file + server.ts defaults are authoritative.

# --- Blockscout Pro API (apps/api) ---
# Used only for ERC-20 contract discovery hints, never for balances.
# Blockscout Pro docs use api.blockscout.com/v2/api with chain_id + apikey.
# Do not assume Pro quota applies to per-explorer /api/v2 routes without verification.
# If the key is exhausted, scans fall back to RPC log discovery.
BLOCKSCOUT_API_KEY=
# Emergency kill-switch: set to 1 to skip Blockscout entirely.
# BLOCKSCOUT_DISABLE=0
# Per-request timeout before falling back to logs.
# BLOCKSCOUT_TIMEOUT_MS=2500
# Cooldown after 402/403/429/5xx/timeout to avoid burning quota.
# BLOCKSCOUT_COOLDOWN_MS=600000
