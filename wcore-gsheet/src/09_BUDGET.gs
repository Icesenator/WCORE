 return true;
 },
 
 /**
 * Clear ALL budget stats - Cleans up legacy entries
 */
 clearAll: function() {
 try {
 var props = PropertiesService.getScriptProperties();
 var all = props.getProperties();
 var deleted = 0;
 
 for (var key in all) {
 if (key.indexOf("BUDGET_") === 0 || key.indexOf("_BUDGET_") >= 0 || key.indexOf("_DYNAMIC_BUDGET_") >= 0) {
 props.deleteProperty(key);
 deleted++;
 }
 }
 
 return deleted;
 } catch (e) {
 return -1;
 }
 }
};

// ============================================================
// CHAIN BUDGET STATS (v4.7.0)
// ============================================================

/**
 * Lightweight execution history per chain (NOT per wallet) stored in SheetCache.
 * This enables dynamic budgets per chain without blowing ScriptProperties quota.
 *
 * Storage: 1 key / chain (config.KEYS.DYNAMIC_BUDGET_PREFIX + 'CHAIN')
 * Payload: compact JSON with last exec_ms samples + EMAs.
 */
var ChainBudgetStats = {

 _key: function(config) {
 try {
 // v4.12.7 FIX: Include chain name to avoid collision between chains
 // Each chain+wallet combination gets its own key
 var chainName = (config && config.CHAIN && config.CHAIN.NAME) ? String(config.CHAIN.NAME) : 'UNKNOWN';
 var safeChain = chainName.replace(/[^a-zA-Z0-9]/g, '_');
 return 'DYNAMIC_BUDGET_STATS_' + safeChain;
 } catch (e) {
 return 'DYNAMIC_BUDGET_STATS_UNKNOWN';
 }
 },

 load: function(config) {
 try {
 var key = this._key(config);
 Logger.log("[ChainBudgetStats.load] key=" + key);
 
 // Use ScriptProperties instead of SheetCache (works from formulas)
 var props = PropertiesService.getScriptProperties();
 var raw = props.getProperty(key);
 
 if (!raw) {
 Logger.log("[ChainBudgetStats.load] No data found");
 return null;
 }
 
 var o = JSON.parse(String(raw));
 if (!o || typeof o !== 'object') return null;
 if (!Array.isArray(o.last)) o.last = [];
 
 Logger.log("[ChainBudgetStats.load] SUCCESS: n=" + (o.n || 0));
 return o;
 } catch (e) {
 Logger.log("[ChainBudgetStats.load] ERROR: " + e.message);
 return null;
 }
 },

 save: function(config, execMs, parts) {
 try {
 if (!Num.isValidPositive(execMs)) {
 Logger.log("[ChainBudgetStats.save] SKIP: invalid execMs=" + execMs);
 return;
 }

 var now = Date.now();
 var key = this._key(config);
 Logger.log("[ChainBudgetStats.save] key=" + key + ", execMs=" + execMs);
 
 var st = this.load(config) || { last: [], ema: 0, n: 0, ts: 0, emaBal: 0, emaPrice: 0, lastExec: 0 };
 Logger.log("[ChainBudgetStats.save] Loaded existing: n=" + (st.n || 0));

 var arr = Array.isArray(st.arr) ? st.arr : (Array.isArray(st.last) ? st.last : []);
 arr.push(execMs | 0);
 while (arr.length > 10) arr.shift();

 var alpha = 0.30;
 var ema = Number(st.ema || 0);
 ema = (ema > 0) ? (ema * (1 - alpha) + (execMs * alpha)) : execMs;

 // Optional phase timing EMAs (balances/prices)
 var bms = parts && Num.isValidPositive(parts.balancesMs) ? Number(parts.balancesMs) : 0;
 var pms = parts && Num.isValidPositive(parts.pricesMs) ? Number(parts.pricesMs) : 0;
 var emaBal = Number(st.emaBal || 0);
 var emaPrice = Number(st.emaPrice || 0);
 if (bms > 0) emaBal = (emaBal > 0) ? (emaBal * (1 - alpha) + (bms * alpha)) : bms;
 if (pms > 0) emaPrice = (emaPrice > 0) ? (emaPrice * (1 - alpha) + (pms * alpha)) : pms;

 st.arr = arr; st.last = arr;
 st.ema = Math.round(ema);
 st.emaBal = Math.round(emaBal);
 st.emaPrice = Math.round(emaPrice);
 st.n = (Number(st.n || 0) + 1) | 0;
 st.ts = now;
 st.lastExec = execMs | 0;
 if (parts && parts.pricesFetched != null) st.lastPricesFetched = parts.pricesFetched | 0;

 Logger.log("[ChainBudgetStats.save] About to write: n=" + st.n + ", arr.length=" + arr.length);
 
 // Use ScriptProperties instead of SheetCache (works from formulas)
 var props = PropertiesService.getScriptProperties();
 props.setProperty(key, JSON.stringify(st));
 
 Logger.log("[ChainBudgetStats.save] Write complete");
 } catch (e) {
 Logger.log("[ChainBudgetStats.save] ERROR: " + e.message);
 }
 },

 percentile: function(arr, p) {
 try {
 if (!arr || !arr.length) return 0;
 var a = arr.slice().sort(function(x, y) { return x - y; });
 var idx = Math.floor((p * (a.length - 1)));
 return a[Math.max(0, Math.min(a.length - 1, idx))] | 0;
 } catch (e) {
 return 0;
 }
 }
};

// ============================================================
// CLEAR BUDGET CACHE (User-facing function)
// ============================================================

/**
 * Clear all BUDGET cache entries to free storage
 * @param {boolean} confirm - Must be TRUE to execute
 * @returns {Array} Result table
 */
function CLEAR_BUDGET_CACHE(confirm) {
 var out = [["Action", "Result", "Details"]];
 
 if (confirm !== true) {
 out.push(["BUDGET Cache", "NOT CLEARED", "Pass TRUE to confirm: =CLEAR_BUDGET_CACHE(TRUE)"]);
 return out;
 }
 
 try {
 var deleted = BudgetStats.clearAll();
 
 if (deleted === 0) {
 out.push(["BUDGET Cache", "EMPTY", "No BUDGET entries found"]);
 } else if (deleted > 0) {
 out.push(["BUDGET Cache", "CLEARED", deleted + " entries deleted"]);
 } else {
 out.push(["BUDGET Cache", "ERROR", "Could not clear entries"]);
 }
 
 } catch (e) {
 out.push(["BUDGET Cache", "ERROR", String(e.message || e)]);
 }
 
 return out;
}

// ============================================================
// DYNAMIC BUDGET V2
// ============================================================

var DynamicBudget = {
 DEFAULT_MAX_EXECUTION_MS: 30000,
 SAFE_MARGIN_MS: 750,
 
 /**
 * v4.10.2 FIX: Compatibility shim for EVM_ENGINE with autoForced support
 * EVM_ENGINE calls: DynamicBudget.compute(address, cache, force, trig, timer, config)
 * This adapts to BudgetManager.compute(timer, opts, address, config)
 * 
 * v4.10.2: Now detects cacheVersionMismatch and autoForced conditions
 * to prevent pricing from being disabled during recovery
 */
 compute: function(address, cache, force, trig, timer, config) {
 // Determine temporal flags from cache
 var nowMs = Date.now();
 var dueFullScan = false;
 var dueFullPrice = false;
 var autoForced = false;
 var cacheVersionMismatch = false;
 
 // v4.10.2: Detect cache version mismatch (same logic as EVM_ENGINE)
 var expectedVersion = (config && config.CACHE_VERSION) || (typeof WCORE_CACHE_VERSION !== 'undefined' ? WCORE_CACHE_VERSION : 10);
 var cacheVersion = (cache && cache.version) ? cache.version : 0;
 if (expectedVersion > 0 && cacheVersion !== expectedVersion) {
 cacheVersionMismatch = true;
 autoForced = true;
 }
 
 if (cache) {
 // v4.12.29: Updated fallbacks to match 2h refresh cycle alignment (8h scan, 6h price)
 var fullScanIntervalMs = (config && config.CACHE && config.CACHE.FULL_SCAN_INTERVAL_MS) || 28800000;
 var fullPriceIntervalMs = (config && config.CACHE && config.CACHE.FULL_PRICE_INTERVAL_MS) || 21600000;
 var autoForceMs = (config && config.CACHE && config.CACHE.AUTO_FORCE_FULL_SCAN_MS) || 86400000;
 var tooOldMs = (config && config.CACHE && config.CACHE.TOO_OLD_MS) || 172800000;
 
 var lastScan = cache.last_full_scan_ms || 0;
 var lastPrice = cache.last_full_price_ms || 0;
 var cacheAge = nowMs - (cache.updatedAt || 0);
 
 dueFullScan = !lastScan || (nowMs - lastScan) > fullScanIntervalMs;
 dueFullPrice = !lastPrice || (nowMs - lastPrice) > fullPriceIntervalMs;
 
 // v4.10.2: Detect autoForced from cache age
 if (cacheAge > autoForceMs || cacheAge > tooOldMs) {
 autoForced = true;
 }
 } else {
 // Cold wallet - needs full scan and price
 dueFullScan = true;
 dueFullPrice = true;
 autoForced = true; // Cold wallet is effectively an auto-force
 }
 
 // Force overrides
 if (force) {
 dueFullScan = true;
 dueFullPrice = true;
 }
 
 var opts = {
 isCold: !cache,
 force: !!force,
 dueFullScan: dueFullScan,
 dueFullPrice: dueFullPrice,
 fastCacheMode: false,
 autoForced: autoForced, // v4.10.2
 cacheVersionMismatch: cacheVersionMismatch // v4.10.2
 };
 
 return BudgetManager.compute(timer, opts, address, config);
 },
 
 /**
 * Create a new budget context
 */
 create: function(timer, config) {
 var profile = BudgetProfiles.get("NORMAL");
 
 return {
 timer: timer,
 config: config,
 profile: profile,
 profileName: "NORMAL",
 phases: {},
 currentPhase: ExecutionPhase.INIT,
 metrics: {
 tokensProcessed: 0,
 pricesFetched: 0,
 httpCalls: 0,
 cacheHits: 0
 }
 };
 },
 
 /**
 * Select profile based on remaining time AND HTTP quota (v4.15.14)
 */
 selectProfile: function(budget, address, stats) {
 if (!budget || !budget.timer) return budget;

 var remaining = budget.timer ? budget.timer.remaining() : 30000;

 // v4.15.14: Quota-aware profile selection
 // Factor in remaining HTTP quota to avoid exhausting quota early
 var quotaPct = 1.0;
 if (typeof HttpCallCounter !== 'undefined') {
   var used = HttpCallCounter.getToday();
   var quota = HttpCallCounter.getQuota();
   if (quota > 0) quotaPct = Math.max(0, (quota - used) / quota);
 }

 // Time-based tier (0=MINIMAL, 1=CONSERVATIVE, 2=NORMAL, 3=AGGRESSIVE, 4=FULL_SCAN)
 var timeTier;
 if (remaining < 2000) timeTier = 0;
 else if (remaining < 5000) timeTier = 1;
 else if (remaining < 10000) timeTier = 2;
 else if (remaining < 20000) timeTier = 3;
 else timeTier = 4;

 // v4.15.14: Quota-based cap — downgrade when quota is tight
 var quotaTier = 4;
 if (quotaPct < 0.05) quotaTier = -1;     // HIBERNATED (cache-only)
 else if (quotaPct < 0.15) quotaTier = 0; // MINIMAL max
 else if (quotaPct < 0.40) quotaTier = 1; // CONSERVATIVE max

 var finalTier = Math.min(timeTier, quotaTier);
 var TIERS = ["MINIMAL", "CONSERVATIVE", "NORMAL", "AGGRESSIVE", "FULL_SCAN"];
 var profileName = finalTier < 0 ? "HIBERNATED" : TIERS[finalTier];

 budget.profile = BudgetProfiles.get(profileName);
 budget.profileName = profileName;
 return budget;
 },
 
 /**
 * Check if we can start a phase
 */
 canStartPhase: function(budget, phase) {
 if (!budget || !budget.timer) return true;
 
 var profile = budget.profile || BudgetProfiles.get("NORMAL");
 var required = (profile.phases && profile.phases[phase]) || 0;
 var remaining = budget.timer.remaining();
 var margin = this.SAFE_MARGIN_MS;
 
 return remaining > (required + margin);
 },
 
 /**
 * Check if we should continue current operation
 */
 shouldContinue: function(budget) {
 if (!budget || !budget.timer) return true;
 return budget.timer.remaining() > this.SAFE_MARGIN_MS;
 },
 
 /**
 * Get remaining budget for a phase
 */
 getPhaseRemaining: function(budget, phase) {
 if (!budget || !budget.timer) return 10000;
 
 var profile = budget.profile || BudgetProfiles.get("NORMAL");
 var allocated = (profile.phases && profile.phases[phase]) || 0;
 var used = (budget.phases && budget.phases[phase]) || 0;
 
 return Math.max(0, allocated - used);
 },
 
 /**
 * Record phase time
 */
 recordPhaseTime: function(budget, phase, ms) {
 if (!budget) return;
 if (!budget.phases) budget.phases = {};
 budget.phases[phase] = (budget.phases[phase] || 0) + ms;
 },
 
 /**
 * Get execution summary (no longer saved)
 */
 getSummary: function(budget) {
 return {
 ts: Date.now(),
 totalMs: budget.timer ? budget.timer.elapsed() : 0,
 profile: budget.profileName || "NORMAL",
 tokensProcessed: budget.metrics ? budget.metrics.tokensProcessed : 0,
 pricesFetched: budget.metrics ? budget.metrics.pricesFetched : 0,
 phases: budget.phases || {}
 };
 }
};

