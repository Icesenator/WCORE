var BudgetTracker = {
 _current: null,
 
 /**
 * Start tracking for an execution
 */
 start: function(address, timer, config) {
 var budget = DynamicBudget.create(timer, config);
 
 // v4.6.0: No longer loads stats, profile selected by time only
 DynamicBudget.selectProfile(budget, address, null);
 
 this._current = {
 address: address,
 budget: budget,
 startMs: Date.now()
 };
 
 return budget;
 },
 
 /**
 * End tracking - v4.6.0: NO LONGER SAVES STATS
 */
 end: function(address, config) {
 if (!this._current || this._current.address !== address) {
 return null;
 }
 
 // v4.6.0: Do NOT save stats to reduce storage
 // BudgetStats.save(address, summary, config);
 
 var result = this._current.budget;
 this._current = null;
 
 return result;
 },
 
 /**
 * Get current budget context
 */
 getCurrent: function() {
 return this._current ? this._current.budget : null;
 }
};

// ============================================================
// ADAPTIVE THROTTLE
// ============================================================

var AdaptiveThrottle = {
 _lastCall: {},
 
 /**
 * Check if an operation should be throttled
 */
 shouldThrottle: function(operationType, minIntervalMs) {
 var now = Date.now();
 var last = this._lastCall[operationType] || 0;
 
 if (now - last < minIntervalMs) {
 return true;
 }
 
 this._lastCall[operationType] = now;
 return false;
 },
 
 /**
 * Reset throttle for an operation
 */
 reset: function(operationType) {
 delete this._lastCall[operationType];
 }
};

// ============================================================
// ROTATION MANAGER
// ============================================================

var RotationManager = {
 TOKENS_PER_BATCH: 5,
 
 /**
 * Get next batch of tokens to process
 */
 getNextBatch: function(allTokens, cursor, budget) {
 if (!allTokens || !allTokens.length) return { tokens: [], cursor: 0, done: true };
 
 var batchSize = this.TOKENS_PER_BATCH;
 if (budget && budget.profile) {
 batchSize = budget.profile.maxTokensPerCall || this.TOKENS_PER_BATCH;
 }
 
 var start = cursor || 0;
 if (start >= allTokens.length) {
 return { tokens: [], cursor: 0, done: true };
 }
 
 var end = Math.min(start + batchSize, allTokens.length);
 var batch = allTokens.slice(start, end);
 var newCursor = end >= allTokens.length ? 0 : end;
 var done = end >= allTokens.length;
 
 return {
 tokens: batch,
 cursor: newCursor,
 done: done,
 progress: end + "/" + allTokens.length
 };
 },
 
 /**
 * Save rotation cursor - stored in wallet cache, not separate
 */
 saveCursor: function(address, cursor, config) {
 // v4.6.0: Cursor is now stored in WalletCache, not separate
 // This method is kept for API compatibility but is a NO-OP
 },
 
 /**
 * Load rotation cursor - from wallet cache
 */
 loadCursor: function(address, config) {
 // v4.6.0: Return 0, cursor managed by WalletCache
 return 0;
 }
};

// ============================================================
// PRICE BUDGET
// ============================================================

var PriceBudget = {
 /**
 * Check if we should fetch price for a token
 */
 shouldFetchPrice: function(tokenKey, budget, priceMap, attemptMap) {
 if (!budget) return true;
 
 // Check if we have budget for more price lookups
 var profile = budget.profile || BudgetProfiles.get("NORMAL");
 var maxLookups = profile.maxPriceLookups || 5;
 var fetched = budget.metrics ? budget.metrics.pricesFetched : 0;
 
 if (fetched >= maxLookups) {
 return false;
 }
 
 // Check if we already have the price
 if (priceMap && priceMap[tokenKey]) {
 return false;
 }
 
 // Check cooldown on failed attempts
 if (attemptMap && attemptMap[tokenKey]) {
 var cooldown = 300000; // 5 minutes
 if (Date.now() - attemptMap[tokenKey] < cooldown) {
 return false;
 }
 }
 
 return true;
 },
 
 /**
 * Record a price fetch
 */
 recordFetch: function(budget) {
 if (budget && budget.metrics) {
 budget.metrics.pricesFetched = (budget.metrics.pricesFetched || 0) + 1;
 }
 }
};

// ============================================================
// EXECUTION CONTEXT (v4.6.0 - Simplified)
// ============================================================

var ExecutionContext = {
 /**
 * Determine execution flags based on timing
 * v4.6.0: No longer uses stored history
 */
 getFlags: function(address, timer, config, force) {
 var now = Date.now();
 
 // v4.6.0: Without history, we use time-based defaults
 // Full scan every hour (from config), full price every 30 min
 var scanCooldown = (config && config.CACHE && config.CACHE.FULL_SCAN_COOLDOWN_MS) || 3600000;
 var priceCooldown = (config && config.CACHE && config.CACHE.FULL_PRICE_COOLDOWN_MS) || 1800000;
 
 // Since we don't store history, we check the wallet cache for timestamps
 var walletCache = null;
 try {
 walletCache = WalletCache.load(address, timer, config);
 } catch (e) {}
 
 var lastScanTs = walletCache ? (walletCache.updatedAt || walletCache.u || 0) : 0;
 var dueFullScan = force || (now - lastScanTs > scanCooldown);
 var dueFullPrice = force || (now - lastScanTs > priceCooldown);
 
 return {
 force: !!force,
 dueFullScan: dueFullScan,
 dueFullPrice: dueFullPrice,
 timeSinceLastScan: now - lastScanTs,
 history: null // No history in v4.6.0
 };
 }
